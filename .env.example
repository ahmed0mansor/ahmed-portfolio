# Database
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/db?sslmode=require"

# AI Provider fallback order
# Best practice: Gemini first, Groq second.
AI_PROVIDER="gemini"
AI_PROVIDER_ORDER="gemini,groq"
AI_TIMEOUT_MS="12000"

# Google Gemini - recommended free/default provider
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash-lite"

# Groq - recommended fallback for very fast chat
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"

# OpenRouter - optional fallback for free-model routing
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openrouter/free"
SITE_URL="http://localhost:3000"
SITE_NAME="Ahmed AI Portfolio"

# Ollama - local development without external API costs
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"

# Admin
ADMIN_TOKEN="change-this-token"

# Optional external notifications for new client leads
# Telegram is recommended because it is simple and fast.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Optional email notification using Resend.
RESEND_API_KEY=""
LEADS_NOTIFY_EMAIL=""
LEADS_NOTIFY_FROM="Ahmed Portfolio <onboarding@resend.dev>"

# Security
# Use your final Vercel domain here after deployment, for strict origin checks.
# Example: https://ahmed-ai-portfolio.vercel.app
NEXT_PUBLIC_SITE_URL=""
